# Token do seu bot Discord (pegue em https://discord.com/developers/applications)
# ATENÇÃO: Habilite no Developer Portal o intent privilegiado Message Content
# se você quiser usar comandos via texto como !play, !addad, !registro-painel etc.
# Habilite o intent Guild Members somente se quiser receber logs de entrada/saída de membros.
DISCORD_TOKEN=MTI4NjMzNjEzNjg1OTM1MzEwOQ.GlT1bL.kVXau87W6h99Y3U-z9xvhpo98dGUxhSkobRpKk

# ID dos canais onde você tem seus anúncios (separados por vírgula)
AD_CHANNEL_IDS=

# Habilite apenas se precisar de logs de entrada/saída de membros
# Essa opção requer o intent privilegiado Guild Members no Discord Developer Portal
ENABLE_GUILD_MEMBERS=false

# Prefixo dos comandos do bot
PREFIX=!

# IDs dos canais de logs (deixe vazio para desativar)
LOG_ENTRADAS_ID=
LOG_SAIDAS_ID=
LOG_BANIMENTOS_ID=
LOG_GERAL_ID=

# ID do servidor para logs (deixe vazio para logs de todos os servidores)
# Para múltiplos servidores, deixe vazio
LOG_SERVER_ID=

# ══════════════════════════════════════
# SISTEMA DE REGISTRO DE FACÇÃO
# ══════════════════════════════════════

# ID do canal onde o painel de registro será enviado (obrigatório)
REGISTRO_PAINEL_CANAL_ID=

# ID do canal onde os registros pendentes serão enviados para aprovação (obrigatório)
REGISTRO_LOG_CANAL_ID=

# ID do cargo que pode aprovar/recusar registros (deixe vazio para permitir apenas administradores)
REGISTRO_CARGO_LIDER_ID=

# ID do cargo que será dado ao membro quando o registro for aprovado (opcional)
REGISTRO_CARGO_APROVADO_ID=

# ID do cargo de recrutador (será dado automaticamente quando recrutar alguém)
REGISTRO_CARGO_RECRUTADOR_ID=

# ══════════════════════════════════════
# SISTEMA DE VERIFICAÇÃO
# ══════════════════════════════════════

# ID do cargo que será dado quando o usuário se verificar
VERIFICACAO_CARGO_ID=

# ══════════════════════════════════════
# SISTEMA DE TICKETS
# ══════════════════════════════════════

# ID do canal onde os logs de tickets serão enviados
TICKETS_LOG_CHANNEL_ID=

# ID do cargo que pode ver e fechar tickets (ex: Staff, Suporte)
TICKETS_CARGO_EQUIPE_ID=

Comandos:Coloca No Canal "!registro-painel"
Comandos:Coloca Na VERIFICAÇÃO "!verificar-painel"
Comandos:Coloca No Canal de Tickets "!ticket-painel"
